{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NRL Pulse",
  "version": "0.0.1",
  "identifier": "com.nrl.pulse",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NRL Pulse",
        "width": 1460,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0RTZGQTdCNDExNkY1M0UKUldRKzlSWkJlL3JtWkk2eUlLNExwTmxabnB1TmcyVDVZbG9NRnpyMmN5L3R4VXFXbXJWcnZSOXIK",
      "endpoints": [
        "https://github.com/hicaoc/nrl-pulse/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
