{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NRL Pulse",
  "version": "0.0.8",
  "identifier": "com.nrl.pulse",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NRL Pulse",
        "width": 1700,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1OTQ0QjBGRUM5RUREQzEKUldUQjNaN3NEMHVVNVNqeHJwMU9JK0tLcHpiSEwvMDdydVRxMjBTV1NsSWFITVcwNnExMGYxMWwK",
      "endpoints": [
        "https://github.com/hicaoc/nrl-pulse/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
